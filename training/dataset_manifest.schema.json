{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://beatmaster.local/schemas/cultural-dataset-manifest.json",
  "title": "BeatMaster Cultural Music Dataset Manifest",
  "type": "object",
  "required": ["dataset_name", "version", "profile_id", "community_reviewers", "recordings"],
  "properties": {
    "dataset_name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "profile_id": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "community_reviewers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "role", "community_affiliation"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "role": {"type": "string", "minLength": 1},
          "community_affiliation": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "recordings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path", "license", "ml_training_consent", "withdrawn", "region", "languages", "performers"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "license": {"type": "string", "minLength": 1},
          "ml_training_consent": {"const": true},
          "commercial_use_allowed": {"type": "boolean"},
          "withdrawn": {"const": false},
          "region": {"type": "string", "minLength": 1},
          "subgenre": {"type": "string"},
          "languages": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "instruments": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "performers": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "recording_year": {"type": ["integer", "null"], "minimum": 1900, "maximum": 2100},
          "split": {"enum": ["train", "validation", "test"]},
          "notes": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
